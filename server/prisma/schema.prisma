// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                @id @default(auto()) @map("_id") @db.ObjectId
  email               String                @unique
  name                String?
  profileImage        String?
  role                UserRoles             @default(User)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  encryptionKey       String?
  kmsEncryptedKey     String?
  userProjectAccesses UserProjectAccess[]
  organizations       Organization[]
  organizationMembers OrganizationMembers[]
  signInCodes         SignInCodes[]
  projects            Projects[]
  envs                Envs[]

  projectGitHostOrigins ProjectGitHostOrigin[]
}

model Organization {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  name    String
  ownerId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner               User                  @relation(fields: [ownerId], references: [id])
  organizationMembers OrganizationMembers[]
  organizationInvites OrganizationInvite[]
  projects            Projects[]
}

model OrganizationMembers {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  userId         String       @db.ObjectId
  organizationId String       @db.ObjectId
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  githubToken    String?
  gitlabToken    String?
  bitBucketToken String?

  createdAt DateTime @default(now())
}

model OrganizationInvite {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  email          String
  organizationId String       @db.ObjectId
  token          String       @unique
  expiresAt      DateTime
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
}

model Projects {
  id                  String              @id @default(auto()) @map("_id") @db.ObjectId
  name                String
  description         String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  projectKey          String
  masterKeyId         String
  kmsEncryptedKey     String
  userProjectAccesses UserProjectAccess[]
  organizationId      String              @db.ObjectId
  organization        Organization        @relation(fields: [organizationId], references: [id])
  createdById         String              @db.ObjectId
  createdBy           User                @relation(fields: [createdById], references: [id])
  environments        Environment[]
  envs                Envs[]

  githubToken            String?
  githubOAuthCompletedAt DateTime?
  githubTokenExpiresAt   DateTime?
  githubRefreshToken     String?

  gitlabToken            String?
  gitlabOAuthCompletedAt DateTime?
  gitlabTokenExpiresAt   DateTime?
  gitlabRefreshToken     String?

  usesSeperateEnvironmentSecrets Boolean @default(false)
  usesActionSecrets              Boolean @default(false)

  initOAuths            InitOAuth[]
  projectGitHostOrigins ProjectGitHostOrigin[]
}

model InitOAuth {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String          @db.ObjectId
  provider    String
  state       String
  project     Projects        @relation(fields: [projectId], references: [id])
  expiresAt   DateTime
  status      InitOAuthStatus @default(Pending)
  redirectUrl String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserProjectAccess {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  userId       String @db.ObjectId
  projectId    String @db.ObjectId
  encryptedKey String

  user    User     @relation(fields: [userId], references: [id])
  project Projects @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
}

model Session {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  userId       String  @db.ObjectId
  accessToken  String
  refreshToken String?
  deviceId     String?
  cliCode      String?

  expiresAt DateTime
}

model SignInCodes {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  code      String
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id])
  expiresAt DateTime
  cliCode   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CliSignInCode {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  deviceCode String

  expiresAt DateTime
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  status    CliSignInStatus @default(Pending)
  email     String?

  @@index([deviceCode])
}

model Environment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  projectId   String   @db.ObjectId
  project     Projects @relation(fields: [projectId], references: [id])
  slug        String
  description String?
  envs        Envs[]

  @@unique([projectId, slug])
}

model Envs {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  environmentId String      @db.ObjectId
  environment   Environment @relation(fields: [environmentId], references: [id])
  projectId     String      @db.ObjectId
  project       Projects    @relation(fields: [projectId], references: [id])
  createdById   String      @db.ObjectId
  createdBy     User        @relation(fields: [createdById], references: [id])
  version       Int         @default(1)
  isDeleted     Boolean     @default(false)
  blobUrl       String
  changelog     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectGitHostOrigin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId String   @db.ObjectId
  project   Projects @relation(fields: [projectId], references: [id])
  name      String
  githost   String
  url       String

  createdAt    DateTime @default(now())
  lastUpdated  DateTime @updatedAt
  lastUsedAt   DateTime @updatedAt
  lastUsedById String?  @db.ObjectId
  lastUsedBy   User?    @relation(fields: [lastUsedById], references: [id])
}

enum UserRoles {
  User
}

enum UserProjectRoles {
  Owner
  Member
}

enum CliSignInStatus {
  Pending
  Completed
  Expired
}

enum InitOAuthStatus {
  Pending
  Completed
  Expired
}
